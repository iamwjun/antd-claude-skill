{
  "name": "antd-claude-skill",
  "version": "0.1.8",
  "description": "Claude Code skill for Ant Design Pro Components - Generate ProTable, ProForm, ProDescriptions pages with best practices",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "bin": {
    "add-skill": "./bin/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "skills"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:cli": "tsc bin/cli.ts --outDir bin --module commonjs --target es2015 --esModuleInterop",
    "dev:example": "cd example && max dev",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --cache --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-skill",
    "agent-skill",
    "antd",
    "ant-design",
    "pro-components",
    "react",
    "typescript",
    "code-generator",
    "scaffold",
    "template",
    "admin",
    "crud",
    "umijs"
  ],
  "author": "iamwjun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamwjun/antd-claude-skill.git"
  },
  "bugs": {
    "url": "https://github.com/iamwjun/antd-claude-skill/issues"
  },
  "homepage": "https://github.com/iamwjun/antd-claude-skill#readme",
  "peerDependencies": {
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0",
    "antd": ">=5.0.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.0.1",
    "@ant-design/pro-components": "^2.4.4",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.33",
    "@types/react-dom": "^18.0.11",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@umijs/max": "^4.6.38",
    "antd": "^5.4.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.33.0",
    "husky": "^9",
    "lint-staged": "^13.2.0",
    "prettier": "^2.8.7",
    "prettier-plugin-organize-imports": "^3.2.2",
    "prettier-plugin-packagejson": "^2.4.3",
    "rollup": "^4.0.0",
    "styled-components": "^6.1.0",
    "tslib": "^2.6.0",
    "typescript": "^5.0.3",
    "zod": "^3.22.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "inquirer": "^8.2.5"
  }
}
